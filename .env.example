# Hugging Face API Configuration
# Get your API token from https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_api_key_here

# Model Configuration
MODEL_NAME=google/gemma-4-31B-it:fastest
BASE_URL=https://router.huggingface.co/v1

# Z.AI API Configuration
# Get your API key from https://z.ai/
ZAI_API_KEY=your_zai_api_key_here
ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# Default model - can be any of:
# Free: glm-4.7-flash, glm-4.5-flash, glm-4.6-flash
# Paid: glm-5, glm-5-turbo, glm-4.7, glm-4.7-flashx, glm-4.6, glm-4.5, glm-4.5-x, glm-4.5-air, glm-4.5-airx, glm-4-32b-0414-128k
ZAI_MODEL=glm-4.7-flash
